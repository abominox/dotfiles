{
  "lastChangelogVersion": "0.79.1",
  "defaultProvider": "openrouter",
  "defaultModel": "deepseek/deepseek-v4-flash",
  "defaultThinkingLevel": "off",
  "terminal": {
    "showTerminalProgress": true
  },
  "hideThinkingBlock": true,
  "packages": [
    "npm:pi-wierd-statusline",
    {
      "source": "git:github.com/tmustier/pi-extensions",
      "extensions": [
        "!files-widget/**",
        "!arcade/**"
      ]
    },
    "npm:pi-qq",
    "npm:pi-rtk-optimizer",
    "npm:@plannotator/pi-extension",
    "npm:pi-tool-display",
    "npm:pi-subagents",
    "npm:pi-intercom"
  ],
  "extensions": [
    "./extensions/ask-lockdown.ts",
    "./extensions/plan-mode"
  ],
  "theme": "dark",
  "editorPaddingX": 2,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "collapseChangelog": false,
  "doubleEscapeAction": "tree",
  "steeringMode": "all",
  "flags": {
    "--recap-model": "openrouter/google/gemini-2.5-flash"
  },
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "researcher": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "planner": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "worker": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "reviewer": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "oracle": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "context-builder": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      },
      "delegate": {
        "model": "openrouter/deepseek/deepseek-v4-flash",
        "thinking": "off"
      }
    }
  }
}