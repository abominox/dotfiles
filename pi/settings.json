{
  "lastChangelogVersion": "0.81.1",
  "defaultProvider": "openrouter",
  "defaultModel": "poolside/laguna-s-2.1",
  "defaultThinkingLevel": "high",
  "terminal": {
    "showTerminalProgress": true
  },
  "hideThinkingBlock": false,
  "packages": [
    "npm:pi-wierd-statusline",
    {
      "source": "git:github.com/tmustier/pi-extensions",
      "extensions": [
        "!files-widget/**",
        "!arcade/**"
      ]
    },
    "git:github.com/DietrichGebert/ponytail",
    "npm:pi-qq",
    "npm:@plannotator/pi-extension",
    "npm:pi-tool-display",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-simplify",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@ff-labs/pi-fff",
    "npm:context-mode",
    "npm:pi-mcp-adapter"
  ],
  "extensions": [
    "./extensions/plan-mode"
  ],
  "theme": "dark",
  "editorPaddingX": 2,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "collapseChangelog": false,
  "doubleEscapeAction": "tree",
  "steeringMode": "all",
  "flags": {
    "--recap-model": "openrouter/google/gemini-2.5-flash"
  },
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      },
      "researcher": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off",
        "tools": [
          "read",
          "write",
          "bash",
          "ctx_fetch_and_index",
          "ctx_search",
          "ctx_index",
          "intercom"
        ],
        "inheritSkills": true,
        "systemPrompt": "You are a research subagent. Use `ketch search`, `ketch scrape`, and `ketch docs` (via bash) for web searches and page fetching. Use `ctx_fetch_and_index` for fetching pages into the knowledge base, then `ctx_search` to query indexed content. Prefer primary sources and official docs. Produce a concise research brief in research.md. Gaps and sources required."
      },
      "planner": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      },
      "worker": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      },
      "reviewer": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      },
      "oracle": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      },
      "context-builder": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      },
      "delegate": {
        "model": "openrouter/poolside/laguna-s-2.1",
        "thinking": "off"
      }
    },
    "watchdog": {
      "children": {
        "model": "openrouter/poolside/laguna-s-2.1"
      }
    }
  },
  "enabledModels": [
    "openrouter/deepseek/deepseek-v4-flash",
    "openrouter/deepseek/deepseek-v4-pro",
    "openrouter/poolside/laguna-s-2.1"
  ]
}
