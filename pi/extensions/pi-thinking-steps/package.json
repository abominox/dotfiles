{
  "name": "pi-thinking-steps",
  "version": "1.0.11",
  "description": "Professional three-mode thinking-step rendering for Pi's TUI.",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluxgear/pi-thinking-steps.git"
  },
  "homepage": "https://github.com/fluxgear/pi-thinking-steps#readme",
  "bugs": {
    "url": "https://github.com/fluxgear/pi-thinking-steps/issues"
  },
  "keywords": [
    "pi",
    "pi-package",
    "terminal",
