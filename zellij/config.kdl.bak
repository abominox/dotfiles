// abominox's zellij config — tmux-parity
// Prefix is Ctrl b (zellij's built-in "tmux" mode). Default keybinds are kept;
// additions below mirror ~/.dotfiles/.tmux.conf.

// ── Options ────────────────────────────────────────────────────────────────

mouse_mode true
pane_frames false
default_shell "fish"
scroll_buffer_size 100000
copy_command "pbcopy"   // macOS. On Linux set "wl-copy" or "xclip -selection clipboard".
styled_underlines true
auto_layout true
session_serialization true
serialize_pane_viewport true
mirror_session true
attach_to_session true

// ── Keybinds ──────────────────────────────────────────────────────────────
// Keep all defaults (including Ctrl b → tmux mode) and add tmux-comfort binds.

keybinds {
    normal {
        // Window switching without prefix (shift+arrow) — .tmux.conf:40-41
        bind "Shift Left"  { GoToPreviousTab; }
        bind "Shift Right" { GoToNextTab; }
        // Window swapping without prefix (ctrl+shift+arrow) — .tmux.conf:44-45
        bind "Ctrl Shift Left"  { MoveTab "Left";  }
        bind "Ctrl Shift Right" { MoveTab "Right"; }
        // Pane focus without prefix (alt+arrow) — .tmux.conf:48-51
        bind "Alt Left"  { MoveFocus "Left";  }
        bind "Alt Right" { MoveFocus "Right"; }
        bind "Alt Up"    { MoveFocus "Up";    }
        bind "Alt Down"  { MoveFocus "Down";  }
    }
    tmux {
        // Pane resize with prefix — .tmux.conf:34-37
        bind "<" { Resize "Increase Left";  SwitchToMode "Normal"; }
        bind ">" { Resize "Increase Right"; SwitchToMode "Normal"; }
        bind "-" { Resize "Increase Down";  SwitchToMode "Normal"; }
        bind "+" { Resize "Increase Up";    SwitchToMode "Normal"; }
    }
}
