layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:/Users/raxemremy/.config/zellij/plugins/zjstatus.wasm" {
                // tmux 256-color palette
                // colour17  = #00005f  dark blue
                // colour85  = #5fffaf  green/cyan
                // colour190 = #d7ff00  chartreuse
                // colour234 = #1c1c1c  near black (main bg)
                // colour238 = #444444  gray
                // colour255 = #eeeeee  white

                // Merikan-style segments:  index  name 
                format_left   "{mode}#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] {session} #[bg=#1c1c1c,fg=#d7ff00] {tabs}"
                format_center ""
                format_right  "{command_systat}{command_host}"
                format_space  "#[bg=#1c1c1c]"
                format_hide_on_overlength "false"

                border_enabled  "false"
                hide_frame_for_single_pane "false"

                // Hide mode badges (esp. TMUX — Ctrl+b prefix mode)
                mode_normal  ""
                mode_tmux    ""
                mode_locked  "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] LOCKED  #[bg=#1c1c1c,fg=#d7ff00] "
                mode_resize  "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] RESIZE #[bg=#1c1c1c,fg=#d7ff00] "
                mode_scroll  "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] SCROLL #[bg=#1c1c1c,fg=#d7ff00] "
                mode_pane    "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] PANE #[bg=#1c1c1c,fg=#d7ff00] "
                mode_tab     "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] TAB #[bg=#1c1c1c,fg=#d7ff00] "
                mode_move    "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] MOVE #[bg=#1c1c1c,fg=#d7ff00] "
                mode_session "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] SESSION #[bg=#1c1c1c,fg=#d7ff00] "
                mode_prompt  "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold] PROMPT #[bg=#1c1c1c,fg=#d7ff00] "

                // Merikan tab style: rounded , colored index chip, name, rounded 
                tab_normal              "#[bg=#1c1c1c,fg=#5fffaf]#[bg=#5fffaf,fg=#00005f,bold]{index} #[bg=#2a2a2a,fg=#5fffaf,bold] {name}{sync_indicator}{fullscreen_indicator}{floating_indicator}#[bg=#1c1c1c,fg=#2a2a2a]"
                tab_normal_fullscreen   "#[bg=#1c1c1c,fg=#5fffaf]#[bg=#5fffaf,fg=#00005f,bold]{index} #[bg=#2a2a2a,fg=#5fffaf,bold] {name}{fullscreen_indicator}#[bg=#1c1c1c,fg=#2a2a2a]"
                tab_normal_sync         "#[bg=#1c1c1c,fg=#5fffaf]#[bg=#5fffaf,fg=#00005f,bold]{index} #[bg=#2a2a2a,fg=#5fffaf,bold] {name}{sync_indicator}#[bg=#1c1c1c,fg=#2a2a2a]"
                tab_active              "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold]{index} #[bg=#444444,fg=#d7ff00,bold] {name}{sync_indicator}{fullscreen_indicator}{floating_indicator}#[bg=#1c1c1c,fg=#444444]"
                tab_active_fullscreen   "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold]{index} #[bg=#444444,fg=#d7ff00,bold] {name}{fullscreen_indicator}#[bg=#1c1c1c,fg=#444444]"
                tab_active_sync         "#[bg=#1c1c1c,fg=#d7ff00]#[bg=#d7ff00,fg=#00005f,bold]{index} #[bg=#444444,fg=#d7ff00,bold] {name}{sync_indicator}#[bg=#1c1c1c,fg=#444444]"
                tab_separator           "#[bg=#1c1c1c] "
                tab_sync_indicator       " "
                tab_fullscreen_indicator " 󰊓"
                tab_floating_indicator   " 󰹙"

                // Fast path: cat + strip colors (no bash -c nesting)
                command_systat_command     "/Users/raxemremy/.dotfiles/zellij/scripts/statusline.sh"
                command_systat_format      "#[bg=#1c1c1c,fg=#444444]#[bg=#444444,fg=#eeeeee] {stdout} "
                command_systat_interval    "1"
                command_systat_rendermode  "static"

                command_host_command      "/bin/hostname -s"
                command_host_format       "#[fg=#d7ff00,bg=#444444]#[fg=#00005f,bg=#d7ff00] {stdout} "
                command_host_interval     "0"
                command_host_rendermode   "static"
            }
        }
    }
}
