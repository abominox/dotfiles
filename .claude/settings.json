{
  "permissions": {
    "allow": [
      "Bash(docker inspect *)",
      "Bash(curl -sI *)",
      "Bash(curl -s \"http*)",
      "Bash(curl -s -H *)",
      "Bash(curl -s -L *)",
      "Bash(curl -s --max-time *)",
      "Bash(pip show *)",
      "Bash(pip list)",
      "Read(*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.bun/bin/ccusage statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium"
}
